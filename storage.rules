rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth()      { return request.auth != null; }
    function uid()         { return request.auth.uid; }

    // documents/{vehicleId}/{filename}
    match /documents/{vehicleId}/{filename} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.size < 20 * 1024 * 1024
                    && request.resource.contentType.matches(
                         "application/(pdf|msword|vnd\\.openxmlformats.*|vnd\\.ms-excel.*)"
                       + "|image/(jpeg|png|gif|webp)");
      allow delete: if isAuth();
    }

    // damage photos (legacy path)
    match /damage/{reportId}/{filename} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.size < 30 * 1024 * 1024
                    && request.resource.contentType.matches("image/(jpeg|png|gif|webp|heic)");
      allow delete: if isAuth();
    }

    // damage report attachments — photos, kosztorys, list przewozowy, wycena
    match /damageReports/{docId}/{category}/{filename} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.size < 30 * 1024 * 1024
                    && request.resource.contentType.matches(
                         "image/(jpeg|png|gif|webp|heic)"
                       + "|application/pdf");
      allow delete: if isAuth();
    }
  }
}
